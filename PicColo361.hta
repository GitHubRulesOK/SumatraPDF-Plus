<html>
<head>
<title>Pick A Colour (3.6.1+)</title>
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<script>
var autoClose = false;   // set to false to keep the picker open
function pick(hex) {
    var fso   = new ActiveXObject("Scripting.FileSystemObject");
    var shell = new ActiveXObject("WScript.Shell");
    var htaPath = unescape(location.pathname.replace("file:///", ""));    // Resolve HTA folder
    htaPath = htaPath.replace(/\//g, "\\");
    if (htaPath.charAt(0) === "\\") htaPath = htaPath.substring(1);
    var folder = fso.GetParentFolderName(htaPath);
    var exe = fso.BuildPath(folder, "SumatraPDF.exe");    // Relative Portable SumatraPDF.exe path
    var cmd = '"' + exe + '" -dde "[CmdCreateAnnotHighlight ' + hex + ']"';    // Build DDE command
    var temp = fso.GetSpecialFolder(2) + "\\run-sumatra-dde.cmd";    // Write temporary CMD launcher
    var file = fso.CreateTextFile(temp, true); file.WriteLine(cmd); file.Close();
    shell.Run('cmd.exe /c "' + temp + '"', 0, false);    // Run it
    if (autoClose) window.close();
}
window.onload = function() {
    var w = 304; var h = 75;    // Set size
    window.resizeTo(w, h);
    var left = (screen.availWidth  - w) / 2; var top  = (screen.availHeight - h) / 2;
    window.moveTo(left, top);    // Center on screen but beware if always "open" it needs to be outside SumatraPDF working area 
};
</script>
</head>
<body style="margin:0;padding:0;overflow:hidden;">
<div style="display:flex;flex-wrap:wrap;width:290px;height:60px;">
<div onclick="pick('#ff0000')" style="width:36px;height:36px;background:#ff0000;cursor:pointer;"></div>
<div onclick="pick('#00ff00')" style="width:36px;height:36px;background:#00ff00;cursor:pointer;"></div>
<div onclick="pick('#800000ff')" style="width:36px;height:36px;background:#0000ff;cursor:pointer;"></div>
<div onclick="pick('#ffff00')" style="width:36px;height:36px;background:#ffff00;cursor:pointer;"></div>
<div onclick="pick('#ff00ff')" style="width:36px;height:36px;background:#ff00ff;cursor:pointer;"></div>
<div onclick="pick('#00ffff')" style="width:36px;height:36px;background:#00ffff;cursor:pointer;"></div>
<div onclick="pick('#80000000')" style="width:36px;height:36px;background:#c0c0c0;cursor:pointer;"></div>
<div onclick="pick('#ff8000')" style="width:36px;height:36px;background:#ff8000;border:1px solid #ccc;cursor:pointer;"></div>
</div>
</body>
</html>
